nix_files=(default.nix nix/sources.nix nix/sources.lock nix/fence-claude.nix)
watch_file "${nix_files[@]}"

store_path_cache="$(direnv_layout_dir)/store-path"
if [[ ! -e $store_path_cache ]] || [[ -n "$(find "${nix_files[@]}" -newer "$store_path_cache" 2>/dev/null)" ]]; then
  mkdir -p "$(direnv_layout_dir)"
  nix-build --no-out-link >"$store_path_cache"
fi
PATH_add "$(<"$store_path_cache")/bin"
